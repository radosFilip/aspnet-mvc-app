@model Filip_Rados_lab2.Models.Tag
@{
    ViewData["Title"] = Model.Name;
    var posts = ViewBag.Posts as List<Filip_Rados_lab2.Models.Post> ?? new();
}

<div class="lh-feed-wrapper">

    <!-- Breadcrumbs -->
    <nav class="lh-breadcrumbs">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>/</span>
        <a asp-controller="Tags" asp-action="Index">Tags</a>
        <span>/</span>
        <span>#@Model.Name</span>
    </nav>

    <!-- Detalji -->
    <div class="lh-card">
        <div class="lh-section-header" style="margin-bottom:1rem;">
            <h3 class="lh-section-title">Detalji taga</h3>
        </div>
        <table class="lh-table">
            <tbody>
                <tr><th>ID</th><td>@Model.Id</td></tr>
                <tr><th>Naziv</th><td><span class="lh-tag">#@Model.Name</span></td></tr>
                <tr><th>Broj postova</th><td>@posts.Count</td></tr>
            </tbody>
        </table>
    </div>

    <!-- Postovi s ovim tagom -->
    @if (posts.Any())
    {
        <div class="lh-card">
            <div class="lh-section-header" style="margin-bottom:1rem;">
                <h3 class="lh-section-title"><i class="fas fa-newspaper" style="margin-right:6px;"></i>Postovi (@posts.Count)</h3>
            </div>
            <table class="lh-table">
                <thead>
                    <tr><th>Naslov</th><th>Kategorija</th><th>Autor</th><th>Datum</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var post in posts)
                    {
                        <tr>
                            <td style="font-weight:600;">@post.Title</td>
                            <td><span class="lh-card__category">@post.Category</span></td>
                            <td>
                                <a asp-controller="Users" asp-action="Details" asp-route-id="@post.AuthorId"
                                   style="color:inherit;text-decoration:none;">@post.Author?.Username</a>
                            </td>
                            <td style="color:var(--color-muted);">@post.CreatedAt.ToString("dd. MM. yyyy.")</td>
                            <td>
                                <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id"
                                   style="font-size:0.78rem;color:var(--color-muted);text-decoration:none;">
                                    Detalji <i class="fas fa-arrow-right" style="font-size:0.65rem;"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div style="margin-top:0.5rem;">
        <a asp-controller="Tags" asp-action="Index"
           style="color:var(--color-muted);font-size:0.85rem;text-decoration:none;">
            <i class="fas fa-arrow-left" style="font-size:0.7rem;margin-right:4px;"></i> Natrag na listu
        </a>
    </div>

</div>
