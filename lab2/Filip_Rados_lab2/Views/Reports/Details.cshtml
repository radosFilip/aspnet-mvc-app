@model Filip_Rados_lab2.Models.Report
@{
    ViewData["Title"] = "Report #" + Model.Id;
}

<div class="lh-feed-wrapper">

    <!-- Breadcrumbs -->
    <nav class="lh-breadcrumbs">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>/</span>
        <a asp-controller="Reports" asp-action="Index">Reports</a>
        <span>/</span>
        <span>Report #@Model.Id</span>
    </nav>

    <!-- Detalji -->
    <div class="lh-card">
        <div class="lh-section-header" style="margin-bottom:1rem;">
            <h3 class="lh-section-title">Detalji reporta</h3>
        </div>
        <table class="lh-table">
            <tbody>
                <tr><th>ID</th><td>@Model.Id</td></tr>
                <tr><th>Razlog</th><td style="font-weight:600;">@Model.Reason</td></tr>
                <tr>
                    <th>Status</th>
                    <td>
                        @if (Model.Status == Filip_Rados_lab2.Models.ReportStatus.Pending)
                        {
                            <span style="color:#d97706;font-weight:600;">Pending</span>
                        }
                        else if (Model.Status == Filip_Rados_lab2.Models.ReportStatus.Reviewed)
                        {
                            <span style="color:#16a34a;font-weight:600;">Reviewed</span>
                        }
                        else
                        {
                            <span style="color:var(--color-muted);font-weight:600;">Dismissed</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Reporter</th>
                    <td>
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.ReporterId"
                           style="color:inherit;text-decoration:none;font-weight:600;">
                            <i class="fas fa-user-circle" style="margin-right:6px;"></i>@Model.Reporter?.Username
                        </a>
                    </td>
                </tr>
                <tr>
                    <th>Prijavljeni post</th>
                    <td>
                        <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.PostId"
                           style="color:inherit;text-decoration:none;">@Model.Post?.Title</a>
                    </td>
                </tr>
                <tr><th>Datum</th><td>@Model.CreatedAt.ToString("dd. MM. yyyy. HH:mm")</td></tr>
            </tbody>
        </table>
    </div>

    <div style="margin-top:0.5rem;">
        <a asp-controller="Reports" asp-action="Index"
           style="color:var(--color-muted);font-size:0.85rem;text-decoration:none;">
            <i class="fas fa-arrow-left" style="font-size:0.7rem;margin-right:4px;"></i> Natrag na listu
        </a>
    </div>

</div>
