@{
    ViewData["Title"] = "LifeHack4Life";
}

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:40vh;gap:1.25rem;text-align:center;margin-bottom:2.5rem;">
    <i class="fas fa-user-circle" style="font-size:6rem;color:var(--color-muted);"></i>
    <h1 style="font-size:2.2rem;font-weight:900;margin:0;">LifeHack4Life</h1>
</div>

<div class="lh-feed-wrapper">
    <div class="lh-section-header">
        <h2 class="lh-section-title">Stranice</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;">

        <a asp-controller="Posts" asp-action="Index" style="text-decoration:none;">
            <div class="lh-card" style="text-align:center;padding:2rem 1rem;cursor:pointer;">
                <i class="fas fa-newspaper" style="font-size:2rem;color:var(--color-muted);margin-bottom:0.75rem;display:block;"></i>
                <div style="font-weight:700;font-size:1rem;">Posts</div>
                <div style="font-size:0.78rem;color:var(--color-muted);margin-top:4px;">Lista svih objava</div>
            </div>
        </a>

        <a asp-controller="Users" asp-action="Index" style="text-decoration:none;">
            <div class="lh-card" style="text-align:center;padding:2rem 1rem;cursor:pointer;">
                <i class="fas fa-users" style="font-size:2rem;color:var(--color-muted);margin-bottom:0.75rem;display:block;"></i>
                <div style="font-weight:700;font-size:1rem;">Users</div>
                <div style="font-size:0.78rem;color:var(--color-muted);margin-top:4px;">Lista svih korisnika</div>
            </div>
        </a>

        <a asp-controller="Comments" asp-action="Index" style="text-decoration:none;">
            <div class="lh-card" style="text-align:center;padding:2rem 1rem;cursor:pointer;">
                <i class="fas fa-comments" style="font-size:2rem;color:var(--color-muted);margin-bottom:0.75rem;display:block;"></i>
                <div style="font-weight:700;font-size:1rem;">Comments</div>
                <div style="font-size:0.78rem;color:var(--color-muted);margin-top:4px;">Lista svih komentara</div>
            </div>
        </a>

        <a asp-controller="Tags" asp-action="Index" style="text-decoration:none;">
            <div class="lh-card" style="text-align:center;padding:2rem 1rem;cursor:pointer;">
                <i class="fas fa-tags" style="font-size:2rem;color:var(--color-muted);margin-bottom:0.75rem;display:block;"></i>
                <div style="font-weight:700;font-size:1rem;">Tags</div>
                <div style="font-size:0.78rem;color:var(--color-muted);margin-top:4px;">Lista svih tagova</div>
            </div>
        </a>

        <a asp-controller="Messages" asp-action="Index" style="text-decoration:none;">
            <div class="lh-card" style="text-align:center;padding:2rem 1rem;cursor:pointer;">
                <i class="fas fa-envelope" style="font-size:2rem;color:var(--color-muted);margin-bottom:0.75rem;display:block;"></i>
                <div style="font-weight:700;font-size:1rem;">Messages</div>
                <div style="font-size:0.78rem;color:var(--color-muted);margin-top:4px;">Lista svih poruka</div>
            </div>
        </a>

        <a asp-controller="Reports" asp-action="Index" style="text-decoration:none;">
            <div class="lh-card" style="text-align:center;padding:2rem 1rem;cursor:pointer;">
                <i class="fas fa-flag" style="font-size:2rem;color:var(--color-muted);margin-bottom:0.75rem;display:block;"></i>
                <div style="font-weight:700;font-size:1rem;">Reports</div>
                <div style="font-size:0.78rem;color:var(--color-muted);margin-top:4px;">Lista svih reporta</div>
            </div>
        </a>

    </div>
</div>
