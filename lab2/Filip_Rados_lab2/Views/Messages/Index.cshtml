@model List<Filip_Rados_lab2.Models.Message>
@{
    ViewData["Title"] = "Messages";
}

<div class="lh-feed-wrapper">

    <div class="lh-section-header">
        <h2 class="lh-section-title">
            Poruke
            <span style="color:var(--color-muted);font-weight:400;font-size:0.85rem;margin-left:8px;">(@Model.Count)</span>
        </h2>
    </div>

    <div class="lh-card" style="padding:0;overflow:hidden;">
        <table class="lh-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Pošiljatelj</th>
                    <th>Primatelj</th>
                    <th>Poruka</th>
                    <th>Datum</th>
                    <th>Pročitano</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var message in Model)
                {
                    <tr>
                        <td style="color:var(--color-muted);">@message.Id</td>
                        <td style="font-weight:600;">
                            <a asp-controller="Users" asp-action="Details" asp-route-id="@message.SenderId"
                               style="color:inherit;text-decoration:none;">
                                <i class="fas fa-user-circle" style="margin-right:6px;color:var(--color-muted);"></i>@message.Sender?.Username
                            </a>
                        </td>
                        <td>
                            <a asp-controller="Users" asp-action="Details" asp-route-id="@message.ReceiverId"
                               style="color:inherit;text-decoration:none;">@message.Receiver?.Username</a>
                        </td>
                        <td>@message.Content</td>
                        <td style="color:var(--color-muted);">@message.SentAt.ToString("dd. MM. yyyy. HH:mm")</td>
                        <td>
                            @if (message.IsRead)
                            {
                                <span style="color:#16a34a;font-size:0.8rem;"><i class="fas fa-check"></i> Da</span>
                            }
                            else
                            {
                                <span style="color:#dc2626;font-size:0.8rem;"><i class="fas fa-times"></i> Ne</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Messages" asp-action="Details" asp-route-id="@message.Id"
                               style="font-size:0.78rem;color:var(--color-muted);text-decoration:none;">
                                Detalji <i class="fas fa-arrow-right" style="font-size:0.65rem;"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
