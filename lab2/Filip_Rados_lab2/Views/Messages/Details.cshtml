@model Filip_Rados_lab2.Models.Message
@{
    ViewData["Title"] = "Poruka #" + Model.Id;
}

<div class="lh-feed-wrapper">

    <!-- Breadcrumbs -->
    <nav class="lh-breadcrumbs">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>/</span>
        <a asp-controller="Messages" asp-action="Index">Messages</a>
        <span>/</span>
        <span>Poruka #@Model.Id</span>
    </nav>

    <!-- Detalji -->
    <div class="lh-card">
        <div class="lh-section-header" style="margin-bottom:1rem;">
            <h3 class="lh-section-title">Detalji poruke</h3>
        </div>
        <table class="lh-table">
            <tbody>
                <tr><th>ID</th><td>@Model.Id</td></tr>
                <tr><th>Sadržaj</th><td>@Model.Content</td></tr>
                <tr>
                    <th>Pošiljatelj</th>
                    <td>
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.SenderId"
                           style="color:inherit;text-decoration:none;font-weight:600;">
                            <i class="fas fa-user-circle" style="margin-right:6px;"></i>@Model.Sender?.Username
                        </a>
                    </td>
                </tr>
                <tr>
                    <th>Primatelj</th>
                    <td>
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.ReceiverId"
                           style="color:inherit;text-decoration:none;font-weight:600;">
                            <i class="fas fa-user-circle" style="margin-right:6px;"></i>@Model.Receiver?.Username
                        </a>
                    </td>
                </tr>
                <tr><th>Datum slanja</th><td>@Model.SentAt.ToString("dd. MM. yyyy. HH:mm")</td></tr>
                <tr>
                    <th>Pročitano</th>
                    <td>
                        @if (Model.IsRead)
                        {
                            <span style="color:#16a34a;font-weight:600;"><i class="fas fa-check"></i> Da</span>
                        }
                        else
                        {
                            <span style="color:#dc2626;font-weight:600;"><i class="fas fa-times"></i> Ne</span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div style="margin-top:0.5rem;">
        <a asp-controller="Messages" asp-action="Index"
           style="color:var(--color-muted);font-size:0.85rem;text-decoration:none;">
            <i class="fas fa-arrow-left" style="font-size:0.7rem;margin-right:4px;"></i> Natrag na listu
        </a>
    </div>

</div>
